# Castport configuration
# Copy to .env (or set as environment variables) — all optional.

# Port the server listens on
PORT=5329

# Password for the /admin panel. CHANGE THIS before deploying publicly.
ADMIN_PASSWORD=admin

# Where the SQLite database + uploaded audio/artwork live (defaults to ./data)
# DATA_DIR=/var/lib/castport

# Public base URL used in the RSS feed for absolute URLs (enclosure, images, links).
# MUST be set to your real https:// domain before submitting your feed to Apple
# Podcasts / Spotify — they reject feeds with localhost URLs.
BASE_URL=http://localhost:5329
